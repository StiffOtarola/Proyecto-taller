# Copia este archivo a ".env" y ajusta los valores
PORT=3000

# --- Conexion MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_password_aqui
DB_NAME=proyecto_taller

# Origen permitido para CORS (el frontend de Ionic)
CORS_ORIGIN=http://localhost:8100

# --- Seguridad ---
# Secreto para firmar/verificar los JWT. OBLIGATORIO en producción (el server
# aborta si falta). Usá una cadena larga y aleatoria.
JWT_SECRET=
# Vida del token (opcional, por defecto 8h).
JWT_EXPIRES_IN=8h

# --- Cuentas semilla (solo para "npm run migrate") ---
# Sin estas contraseñas, el seed NO crea las cuentas (evita credenciales conocidas).
# Definilas con valores fuertes (mín. 8 caracteres) solo para el bootstrap inicial.
SEED_ADMIN_EMAIL=admin@taller.com
SEED_ADMIN_PASSWORD=
SEED_RECEP_EMAIL=recepcion@taller.com
SEED_RECEP_PASSWORD=

# --- Correo (Resend) para recuperación de contraseña ---
# Sin RESEND_API_KEY, el código se imprime en consola (modo desarrollo).
# Con onboarding@resend.dev solo se entrega a tu propia casilla verificada;
# para enviar a clientes reales verificá un dominio en Resend.
RESEND_API_KEY=
MAIL_FROM=Taller MS <onboarding@resend.dev>
